# ============================================
# Claude Code 轻量执行镜像
# 用于 docker run --rm 临时容器执行 claudecode agent
# ============================================
FROM node:22-alpine

LABEL app="hh-claudecode"
LABEL description="Lightweight Claude Code execution container"

RUN apk add --no-cache git bash \
    && npm install -g @anthropic-ai/claude-code

# 非 root 用户，与 worker 的 appuser UID 一致
RUN adduser -D -u 1000 claudeuser

USER claudeuser
WORKDIR /workspace
